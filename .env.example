# =============================================================================
# Local development only — not used by Cloud Run production deploys.
# Copy to .env (backend) and/or .env.local (frontend overrides).
# =============================================================================

# --- Frontend (Vite: .env.local or .env) ---
# Point at local ADK server, or leave unset and use VITE_GEMINI_API_KEY instead.
VITE_ADK_API_URL=http://127.0.0.1:8000
# VITE_GEMINI_API_KEY=

# --- Backend (ADK reads .env from repo root via adk/main.py) ---
# Option A — API key (simplest for local dev without gcloud):
# GOOGLE_API_KEY=
# Option B — Vertex AI (same auth path as Cloud Run):
GOOGLE_CLOUD_PROJECT=
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_LOCATION=global
AGENT_COUNCIL_MODEL=gemini-3.5-flash
ADK_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SESSION_SERVICE_URI=sqlite+aiosqlite:///./sessions.db

# =============================================================================
# Cloud deploy — export in your shell before npm run gcp:setup / gcp:deploy
# =============================================================================
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# CLOUD_RUN_REGION=us-central1
# GOOGLE_CLOUD_LOCATION=global
# AGENT_COUNCIL_MODEL=gemini-3.5-flash
